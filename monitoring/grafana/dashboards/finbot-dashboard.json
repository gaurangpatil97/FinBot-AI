{
  "title": "FinBot Monitoring",
  "uid": "finbot-monitoring",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))",
          "legendFormat": "p50 {{handler}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))",
          "legendFormat": "p95 {{handler}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))",
          "legendFormat": "p99 {{handler}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Request Rate (per endpoint)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (handler, status)",
          "legendFormat": "{{handler}} [{{status}}]",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (4xx/5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[5m])) by (handler, status)",
          "legendFormat": "{{handler}} [{{status}}]",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "ChromaDB Query Latency by Collection Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(chroma_query_latency_seconds_bucket[5m])) by (le, collection_type))",
          "legendFormat": "p95 {{collection_type}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(chroma_query_latency_seconds_sum[5m])) by (collection_type) / sum(rate(chroma_query_latency_seconds_count[5m])) by (collection_type)",
          "legendFormat": "avg {{collection_type}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "title": "OpenAI API Call Latency (avg by model & purpose)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(openai_api_call_latency_seconds_sum[5m])) by (model, purpose) / sum(rate(openai_api_call_latency_seconds_count[5m])) by (model, purpose)",
          "legendFormat": "{{model}} - {{purpose}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "OpenAI API Call Count (by model, purpose, status)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(openai_api_call_total[5m])) by (model, purpose, status)",
          "legendFormat": "{{model}} - {{purpose}} [{{status}}]",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Active Requests In-Flight",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(http_requests_inprogress)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Total Requests (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Total OpenAI Calls (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(openai_api_call_total[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "OpenAI Error Rate (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(openai_api_call_total{status=\"error\"}[1h])) / sum(increase(openai_api_call_total[1h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Recent Logs",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "{job=\"finbot\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
